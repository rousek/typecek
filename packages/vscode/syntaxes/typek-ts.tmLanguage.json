{
  "scopeName": "source.ts.typek",
  "name": "Typek TypeScript",
  "patterns": [
    { "include": "#raw-block-ts" },
    { "include": "text.typek#type-directive" },
    { "include": "text.typek#comment" },
    { "include": "text.typek#raw-expression" },
    { "include": "text.typek#block-close" },
    { "include": "text.typek#block-open" },
    { "include": "text.typek#partial" },
    { "include": "text.typek#escaped-braces" },
    { "include": "text.typek#expression" },
    { "include": "source.ts" }
  ],
  "repository": {
    "raw-block-ts": {
      "name": "meta.raw-block.typek",
      "begin": "\\{\\{#raw\\}\\}",
      "beginCaptures": {
        "0": { "name": "keyword.control.raw.typek" }
      },
      "end": "\\{\\{/raw\\}\\}",
      "endCaptures": {
        "0": { "name": "keyword.control.raw.typek" }
      },
      "patterns": [
        { "include": "source.ts" }
      ]
    }
  }
}
